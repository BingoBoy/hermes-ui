# ============================================================
# Hermes UI for Bob - example environment file
# Copy this file to .env on Bob and fill in real local values.
# Never commit the real .env file.
# ============================================================

# App
HERMES_UI_ENV=development
HERMES_UI_HOST=127.0.0.1
HERMES_UI_PORT=8787
HERMES_UI_PUBLIC_URL=

# Bob / Mac Mini M4
BOB_HOSTNAME=Truls-sin-Mac-mini.local
BOB_LOCAL_HOSTNAME=Truls-sin-Mac-mini
BOB_LOCAL_IP=192.168.0.106
BOB_SSH_USER=trulsdahl
BOB_SSH_ALIAS=Bob
BOB_REMOTE_SSH_ALIAS=BobRemote
BOB_EXTERNAL_SSH_HOST=bob-ssh.strategistudio.no

# Hermes
HERMES_INSTALL_DIR=/Users/trulsdahl/.hermes/hermes-agent
HERMES_BIN=/Users/trulsdahl/.local/bin/hermes
HERMES_VENV_BIN=/Users/trulsdahl/.hermes/hermes-agent/venv/bin/hermes
HERMES_LAUNCHD_LABEL=ai.hermes.gateway
HERMES_LAUNCHD_PLIST=/Users/trulsdahl/Library/LaunchAgents/ai.hermes.gateway.plist
HERMES_WORKDIR=/Users/trulsdahl/.hermes/hermes-agent
HERMES_LOG_FILE=

# Hermes commands - must be verified before enabling write actions
HERMES_STATUS_COMMAND=launchctl list | grep -i hermes
HERMES_START_COMMAND=
HERMES_STOP_COMMAND=
HERMES_RESTART_COMMAND=

# Cloudflare
CLOUDFLARE_TUNNEL_NAME=
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_TUNNEL_CONFIG_PATH=
CLOUDFLARE_ACCESS_AUDIENCE=
CLOUDFLARE_ACCESS_TEAM_DOMAIN=

# LM Studio
LM_STUDIO_ENABLED=false
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=qwen2.5-coder-7b-instruct
LM_STUDIO_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# Optional local services
N8N_ENABLED=false
N8N_LOCAL_URL=http://127.0.0.1:5678
PAAPP_ENABLED=false
PAAPP_LOCAL_URL=

# Security
HERMES_UI_API_TOKEN=
ALLOW_UNSAFE_COMMANDS=false

# Logging
HERMES_UI_AUDIT_LOG=
HERMES_UI_MAX_LOG_LINES=500
