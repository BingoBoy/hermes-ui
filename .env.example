# ============================================================
# Hermes UI for Bob - example environment file
# Copy this file to .env on Bob and fill in real local values.
# Never commit the real .env file.
# ============================================================

# App
HERMES_UI_ENV=development
HERMES_UI_HOST=127.0.0.1
HERMES_UI_PORT=8787
HERMES_UI_PUBLIC_URL=

# Bob / Mac Mini M4
BOB_HOSTNAME=
BOB_LOCAL_HOSTNAME=
BOB_LOCAL_IP=
BOB_SSH_USER=
BOB_SSH_ALIAS=
BOB_REMOTE_SSH_ALIAS=
BOB_EXTERNAL_SSH_HOST=

# Hermes
HERMES_INSTALL_DIR=
HERMES_BIN=
HERMES_VENV_BIN=
HERMES_LAUNCHD_LABEL=
HERMES_LAUNCHD_PLIST=
HERMES_WORKDIR=
HERMES_LOG_FILE=
HERMES_GATEWAY_STDOUT_LOG=
HERMES_GATEWAY_STDERR_LOG=

# Hermes commands - must be verified before enabling write actions
HERMES_STATUS_COMMAND=
HERMES_START_COMMAND=
HERMES_STOP_COMMAND=
HERMES_RESTART_COMMAND=

# Cloudflare
CLOUDFLARE_TUNNEL_NAME=
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_TUNNEL_CONFIG_PATH=
CLOUDFLARE_ACCESS_AUDIENCE=
CLOUDFLARE_ACCESS_TEAM_DOMAIN=

# LM Studio
LM_STUDIO_ENABLED=false
LM_STUDIO_BASE_URL=
LM_STUDIO_MODEL=
LM_STUDIO_EMBEDDING_MODEL=

# Optional local services
N8N_ENABLED=false
N8N_LOCAL_URL=http://127.0.0.1:5678
PAAPP_ENABLED=false
PAAPP_LOCAL_URL=

# Security
HERMES_UI_API_TOKEN=
ALLOW_UNSAFE_COMMANDS=false

# Logging
HERMES_UI_AUDIT_LOG=
HERMES_UI_MAX_LOG_LINES=500
